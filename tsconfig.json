{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["svelte", "jest", "node"],
        "strict": true,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "sourceMap": true
    },
    "include": [
        "src/pat/filemanager/**/*.ts",
        "src/pat/filemanager/**/*.svelte",
        "src/pat/filemanager/**/*.svelte.ts"
    ],
    "exclude": ["node_modules", "dist", "_site"]
}
